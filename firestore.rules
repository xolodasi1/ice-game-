rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: games
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, < 100 chars)
    //   - description: string (required, < 5000 chars)
    //   - version: string (required, < 50 chars)
    //   - fileUrl: string (required, valid URL)
    //   - fileName: string (required, < 200 chars)
    //   - releaseNotes: string (optional, < 5000 chars)
    //   - views: number (required, >= 0)
    //   - downloads: number (required, >= 0)
    //   - createdAt: number (required)
    //   - authorUid: string (required, immutable)
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      let isDocExists = exists(/databases/$(database)/documents/settings/general);
      let settingsData = isDocExists ? get(/databases/$(database)/documents/settings/general).data : {};
      let adminEmails = 'adminEmails' in settingsData ? settingsData.adminEmails : ["xolodtop889@gmail.com"];
      let finalAdminEmails = (adminEmails is list) ? adminEmails : ["xolodtop889@gmail.com"];
      return isAuthenticated() && request.auth.token.email_verified == true && 
             (request.auth.token.email in finalAdminEmails || request.auth.token.email == "xolodtop889@gmail.com");
    }

    function isOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.authorUid;
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidGame(data) {
      return hasRequiredFields(['title', 'description', 'version', 'fileUrl', 'fileName', 'views', 'downloads', 'createdAt', 'authorUid', 'platform']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.description is string && data.description.size() < 5000 &&
             data.version is string && data.version.size() < 50 &&
             isValidUrl(data.fileUrl) &&
             data.fileName is string && data.fileName.size() < 200 &&
             data.views is number && data.views >= 0 &&
             data.downloads is number && data.downloads >= 0 &&
             data.createdAt is number &&
             data.authorUid is string && data.authorUid.size() > 0 &&
             data.platform in ['pc', 'android', 'both'] &&
             (!('releaseNotes' in data) || (data.releaseNotes is string && data.releaseNotes.size() < 5000)) &&
             (!('logoUrl' in data) || data.logoUrl == "" || isValidUrl(data.logoUrl)) &&
             (!('previewUrl' in data) || data.previewUrl == "" || isValidUrl(data.previewUrl)) &&
             (!('likedBy' in data) || data.likedBy is list) &&
             (!('dislikedBy' in data) || data.dislikedBy is list);
    }

    function isValidSettings(data) {
      return (!('siteName' in data) || (data.siteName is string && data.siteName.size() < 100)) &&
             (!('siteDescription' in data) || (data.siteDescription is string && data.siteDescription.size() < 500)) &&
             (!('siteAvatar' in data) || data.siteAvatar == "" || isValidUrl(data.siteAvatar)) &&
             (!('vkUrl' in data) || data.vkUrl == "" || isValidUrl(data.vkUrl)) &&
             (!('telegramUrl' in data) || data.telegramUrl == "" || isValidUrl(data.telegramUrl)) &&
             (!('youtubeUrl' in data) || data.youtubeUrl == "" || isValidUrl(data.youtubeUrl)) &&
             (!('adminEmails' in data) || (data.adminEmails is list && data.adminEmails.size() > 0 && data.adminEmails.size() < 100));
    }

    function isValidComment(data) {
      return hasRequiredFields(['gameId', 'authorName', 'text', 'createdAt']) &&
             data.gameId is string && data.gameId.size() > 0 &&
             data.authorName is string && data.authorName.size() > 0 && data.authorName.size() <= 50 &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 1000 &&
             data.createdAt is number &&
             (!('likedBy' in data) || data.likedBy is list);
    }

    function isValidNotification(data) {
      return hasRequiredFields(['type', 'message', 'read', 'createdAt']) &&
             data.type in ['new_comment'] &&
             data.message is string && data.message.size() > 0 &&
             data.read is bool &&
             data.createdAt is number &&
             (!('gameId' in data) || data.gameId is string) &&
             (!('gameTitle' in data) || data.gameTitle is string) &&
             (!('authorName' in data) || data.authorName is string);
    }

    function isOnlyIncrementingCommentStats() {
      let diff = request.resource.data.diff(resource.data);
      let allowedKeys = diff.affectedKeys().hasOnly(['likedBy']);
      let votesValid = !diff.affectedKeys().hasAny(['likedBy']) || isAuthenticated();
      return allowedKeys && votesValid;
    }

    function isOnlyIncrementingStats() {
      let diff = request.resource.data.diff(resource.data);
      let allowedKeys = diff.affectedKeys().hasOnly(['views', 'downloads', 'likedBy', 'dislikedBy']);
      
      let viewsValid = !diff.affectedKeys().hasAny(['views']) || 
                       (request.resource.data.views is number && request.resource.data.views == resource.data.views + 1);
                       
      let downloadsValid = !diff.affectedKeys().hasAny(['downloads']) || 
                           (request.resource.data.downloads is number && request.resource.data.downloads == resource.data.downloads + 1);
                           
      let votesValid = !diff.affectedKeys().hasAny(['likedBy', 'dislikedBy']) || isAuthenticated();
                           
      return allowedKeys && viewsValid && downloadsValid && votesValid;
    }

    match /games/{gameId} {
      allow read: if true;
      allow create: if isAdmin() && 
                       isValidGame(request.resource.data) && 
                       request.resource.data.authorUid == request.auth.uid &&
                       request.resource.data.views == 0 &&
                       request.resource.data.downloads == 0;
      allow update: if (isAdmin() && isValidGame(request.resource.data) && request.resource.data.authorUid == resource.data.authorUid) || 
                       isOnlyIncrementingStats();
      allow delete: if isAdmin() && isOwner();
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidComment(request.resource.data);
      allow update: if isAdmin() || isOnlyIncrementingCommentStats();
      allow delete: if isAdmin();
    }

    match /settings/{document} {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }

    match /notifications/{notificationId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidNotification(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Keep legacy rules for backward compatibility during transition
    match /game_data/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
