rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: games
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, < 100 chars)
    //   - description: string (required, < 5000 chars)
    //   - version: string (required, < 50 chars)
    //   - fileUrl: string (required, valid URL)
    //   - fileName: string (required, < 200 chars)
    //   - releaseNotes: string (optional, < 5000 chars)
    //   - views: number (required, >= 0)
    //   - downloads: number (required, >= 0)
    //   - createdAt: number (required)
    //   - authorUid: string (required, immutable)
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      let isDocExists = exists(/databases/$(database)/documents/settings/general);
      let settingsData = isDocExists ? get(/databases/$(database)/documents/settings/general).data : {};
      let adminEmails = 'adminEmails' in settingsData ? settingsData.adminEmails : ["xolodtop889@gmail.com"];
      let finalAdminEmails = (adminEmails is list) ? adminEmails : ["xolodtop889@gmail.com"];
      return isAuthenticated() && request.auth.token.email_verified == true && 
             (request.auth.token.email in finalAdminEmails || request.auth.token.email == "xolodtop889@gmail.com");
    }

    function isOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.authorUid;
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidGame(data) {
      return hasRequiredFields(['title', 'description', 'version', 'fileUrl', 'fileName', 'views', 'downloads', 'createdAt', 'authorUid', 'platform']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.description is string && data.description.size() < 5000 &&
             data.version is string && data.version.size() < 50 &&
             isValidUrl(data.fileUrl) &&
             data.fileName is string && data.fileName.size() < 200 &&
             data.views is number && data.views >= 0 &&
             data.downloads is number && data.downloads >= 0 &&
             data.createdAt is number &&
             data.authorUid is string && data.authorUid.size() > 0 &&
             data.platform in ['pc', 'android', 'both'] &&
             (!('genre' in data) || (data.genre is string && data.genre.size() < 50)) &&
             (!('tags' in data) || (data.tags is list && data.tags.size() <= 20)) &&
             (!('releaseNotes' in data) || (data.releaseNotes is string && data.releaseNotes.size() < 5000)) &&
             (!('logoUrl' in data) || data.logoUrl == "" || isValidUrl(data.logoUrl)) &&
             (!('previewUrl' in data) || data.previewUrl == "" || isValidUrl(data.previewUrl)) &&
             (!('likedBy' in data) || data.likedBy is list) &&
             (!('dislikedBy' in data) || data.dislikedBy is list) &&
             (!('screenshots' in data) || data.screenshots is list) &&
             (!('systemRequirements' in data) || data.systemRequirements is map) &&
             (!('ratings' in data) || data.ratings is list) &&
             (!('versions' in data) || data.versions is list) &&
             (!('developmentProgress' in data) || (data.developmentProgress is number && data.developmentProgress >= 0 && data.developmentProgress <= 100));
    }

    function isValidSettings(data) {
      return (!('siteName' in data) || (data.siteName is string && data.siteName.size() < 100)) &&
             (!('siteDescription' in data) || (data.siteDescription is string && data.siteDescription.size() < 500)) &&
             (!('siteAvatar' in data) || data.siteAvatar == "" || isValidUrl(data.siteAvatar)) &&
             (!('vkUrl' in data) || data.vkUrl == "" || isValidUrl(data.vkUrl)) &&
             (!('telegramUrl' in data) || data.telegramUrl == "" || isValidUrl(data.telegramUrl)) &&
             (!('youtubeUrl' in data) || data.youtubeUrl == "" || isValidUrl(data.youtubeUrl)) &&
             (!('discordUrl' in data) || data.discordUrl == "" || isValidUrl(data.discordUrl)) &&
             (!('adminEmails' in data) || (data.adminEmails is list && data.adminEmails.size() > 0 && data.adminEmails.size() < 100));
    }

    function isValidComment(data) {
      return hasRequiredFields(['gameId', 'authorName', 'text', 'createdAt']) &&
             data.gameId is string && data.gameId.size() > 0 &&
             data.authorName is string && data.authorName.size() > 0 && data.authorName.size() <= 50 &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 1000 &&
             data.createdAt is number &&
             (!('likedBy' in data) || data.likedBy is list) &&
             (!('isDeveloper' in data) || data.isDeveloper is bool) &&
             (!('type' in data) || data.type in ['comment', 'bug_report']) &&
             (!('authorUid' in data) || data.authorUid is string);
    }

    function isValidNotification(data) {
      return hasRequiredFields(['type', 'message', 'read', 'createdAt']) &&
             data.type in ['new_comment', 'new_bug_report'] &&
             data.message is string && data.message.size() > 0 &&
             data.read is bool &&
             data.createdAt is number &&
             (!('gameId' in data) || data.gameId is string) &&
             (!('gameTitle' in data) || data.gameTitle is string) &&
             (!('authorName' in data) || data.authorName is string);
    }

    function isValidUserGameData(data) {
      return hasRequiredFields(['userId', 'gameId']) &&
             data.userId is string && data.userId.size() > 0 &&
             data.gameId is string && data.gameId.size() > 0 &&
             (!('isFavorite' in data) || data.isFavorite is bool) &&
             (!('status' in data) || data.status in ['none', 'playing', 'completed', 'dropped']);
    }

    function isValidDailyStats(data) {
      return hasRequiredFields(['date', 'downloads']) &&
             data.date is string && data.date.size() > 0 &&
             data.downloads is number && data.downloads >= 0;
    }

    function isValidAchievement(data) {
      return hasRequiredFields(['userId', 'gameId', 'title', 'unlockedAt']) &&
             data.userId is string && data.userId.size() > 0 &&
             data.gameId is string && data.gameId.size() > 0 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.unlockedAt is number &&
             (!('description' in data) || (data.description is string && data.description.size() < 500)) &&
             (!('iconUrl' in data) || data.iconUrl == "" || isValidUrl(data.iconUrl));
    }

    function isValidLeaderboardEntry(data) {
      return hasRequiredFields(['gameId', 'userId', 'userName', 'createdAt']) &&
             data.gameId is string && data.gameId.size() > 0 &&
             data.userId is string && data.userId.size() > 0 &&
             data.userName is string && data.userName.size() > 0 && data.userName.size() <= 50 &&
             data.createdAt is number &&
             ((!('score' in data) || data.score is number) || (!('time' in data) || data.time is number));
    }

    function isValidMod(data) {
      return hasRequiredFields(['gameId', 'authorUid', 'authorName', 'title', 'fileUrl', 'createdAt']) &&
             data.gameId is string && data.gameId.size() > 0 &&
             data.authorUid is string && data.authorUid.size() > 0 &&
             data.authorName is string && data.authorName.size() > 0 && data.authorName.size() <= 50 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             isValidUrl(data.fileUrl) &&
             data.createdAt is number &&
             (!('description' in data) || (data.description is string && data.description.size() < 5000)) &&
             (!('downloads' in data) || (data.downloads is number && data.downloads >= 0));
    }

    function isValidDevLog(data) {
      return hasRequiredFields(['title', 'content', 'createdAt', 'authorUid']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 10000 &&
             data.createdAt is number &&
             data.authorUid is string && data.authorUid.size() > 0;
    }

    function isOnlyIncrementingCommentStats() {
      let diff = request.resource.data.diff(resource.data);
      let allowedKeys = diff.affectedKeys().hasOnly(['likedBy']);
      let votesValid = !diff.affectedKeys().hasAny(['likedBy']) || isAuthenticated();
      return allowedKeys && votesValid;
    }

    function isOnlyIncrementingStats() {
      let diff = request.resource.data.diff(resource.data);
      let allowedKeys = diff.affectedKeys().hasOnly(['views', 'downloads', 'likedBy', 'dislikedBy', 'ratings']);
      
      let viewsValid = !diff.affectedKeys().hasAny(['views']) || 
                       (request.resource.data.views is number && request.resource.data.views == resource.data.views + 1);
                       
      let downloadsValid = !diff.affectedKeys().hasAny(['downloads']) || 
                           (request.resource.data.downloads is number && request.resource.data.downloads == resource.data.downloads + 1);
                           
      let votesValid = !diff.affectedKeys().hasAny(['likedBy', 'dislikedBy', 'ratings']) || isAuthenticated();
                           
      return allowedKeys && viewsValid && downloadsValid && votesValid;
    }

    match /games/{gameId} {
      allow read: if true;
      allow create: if isAdmin() && 
                       isValidGame(request.resource.data) && 
                       request.resource.data.authorUid == request.auth.uid &&
                       request.resource.data.views == 0 &&
                       request.resource.data.downloads == 0;
      allow update: if (isAdmin() && isValidGame(request.resource.data) && request.resource.data.authorUid == resource.data.authorUid) || 
                       isOnlyIncrementingStats();
      allow delete: if isAdmin() && isOwner();
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidComment(request.resource.data);
      allow update: if isAdmin() || isOnlyIncrementingCommentStats();
      allow delete: if isAdmin();
    }

    match /settings/{document} {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }

    match /notifications/{notificationId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidNotification(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /userGameData/{dataId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidUserGameData(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isValidUserGameData(request.resource.data) && request.resource.data.userId == resource.data.userId && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /dailyStats/{statId} {
      allow read: if isAdmin();
      allow create: if true; // allow anyone to increment downloads
      allow update: if true; // allow anyone to increment downloads
      allow delete: if isAdmin();
    }

    match /achievements/{achievementId} {
      allow read: if true;
      allow create: if isAdmin() && isValidAchievement(request.resource.data);
      allow update: if isAdmin() && isValidAchievement(request.resource.data);
      allow delete: if isAdmin();
    }

    match /leaderboards/{entryId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidLeaderboardEntry(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isValidLeaderboardEntry(request.resource.data) && request.resource.data.userId == resource.data.userId && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /mods/{modId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidMod(request.resource.data) && request.resource.data.authorUid == request.auth.uid;
      allow update: if isAuthenticated() && isValidMod(request.resource.data) && request.resource.data.authorUid == resource.data.authorUid && resource.data.authorUid == request.auth.uid;
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.authorUid == request.auth.uid);
    }

    match /devlogs/{logId} {
      allow read: if true;
      allow create: if isAdmin() && isValidDevLog(request.resource.data) && request.resource.data.authorUid == request.auth.uid;
      allow update: if isAdmin() && isValidDevLog(request.resource.data) && request.resource.data.authorUid == resource.data.authorUid;
      allow delete: if isAdmin();
    }

    // Keep legacy rules for backward compatibility during transition
    match /game_data/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
